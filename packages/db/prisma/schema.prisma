generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  Admin
  User
}

model User {
  id        String   @id @default(cuid())
  username  String
  password  String
  email     String   @unique
  role      Role     @default(User)
  avatarId  String?
  avatar    Avatar?  @relation(fields: [avatarId], references: [id])
  spaces    Space[]
  createdAt DateTime @default(now())
}

model Avatar {
  id       String  @id @default(cuid())
  imageUrl String?
  name     String?
  users    User[]
}

model Elements {
  id       String          @id @default(cuid())
  width    Int
  height   Int
  imageUrl String
  static   Boolean
  spaces   spaceElements[]
  maps     mapElements[]
}

model Map {
  id          String        @id @default(cuid())
  name        String
  width       Int
  height      Int
  thumbnail   String?
  mapElements mapElements[]
  spaces      Space[]
}

model Space {
  id        String          @id @default(cuid())
  name      String
  width     Int
  height    Int
  thumbnail String?
  creatorId String
  creator   User            @relation(fields: [creatorId], references: [id])
  mapId     String?
  map       Map?            @relation(fields: [mapId], references: [id])
  elements  spaceElements[]
  createdAt DateTime        @default(now())
}

model spaceElements {
  id        String   @id @default(cuid())
  elementId String
  element   Elements @relation(fields: [elementId], references: [id])
  spaceId   String
  space     Space    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  x         Int
  y         Int
}

model mapElements {
  id        String    @id @default(cuid())
  mapId     String
  map       Map       @relation(fields: [mapId], references: [id], onDelete: Cascade)
  elementId String?
  element   Elements? @relation(fields: [elementId], references: [id])
  x         Int?
  y         Int?
}
